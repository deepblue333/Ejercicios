if PARAMIKO_AVAILABLE:
    class AttackerProfiler:
        """Profiles attacker tools and creates fingerprints."""
        SIGNATURES = {
            "sqlmap": [r"sqlmap", r"ORDER BY", r"UNION SELECT"],
            "nmap": [r"Nmap", r"Nmap Scripting Engine"],
            "metasploit": [r"meterpreter", r"rev_tcp", r"payload"],
            "hydra": [r"hydra", r"login:", r"password:"],
            "brute_force": [r"admin", r"root", r"123456", r"password"]
        }

        @staticmethod
        def identify_tool(commands: List[str], attempts: List[Dict]) -> List[str]:
            detected = set()
            blob = (" ".join(commands) + " " + " ".join([str(a) for a in attempts])).lower()
            for tool, patterns in AttackerProfiler.SIGNATURES.items():
                if any(re.search(p, blob) for p in patterns):
                    detected.add(tool)
            return list(detected)

        @staticmethod
        def get_actor_hash(ip: str, tools: List[str]) -> str:
            seed = f"{ip}{''.join(sorted(tools))}"
            return hashlib.sha256(seed.encode()).hexdigest()[:12]

        @staticmethod
        def client_fingerprint(transport) -> Dict:
            try:
                return {
                    "client_version": transport.remote_version,
                    "ciphers": transport.get_security_options().ciphers,
                    "kex_algorithms": transport.get_security_options().kex
                }
            except:
                return {}

