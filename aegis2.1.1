class SystemService:
    """Executes privileged system commands."""
    @staticmethod
    def check_dep(cmd: str) -> bool:
        try:
            return subprocess.run(["which", cmd], capture_output=True).returncode == 0
        except:
            return False

    @staticmethod
    def run_elevated(script: str) -> bool:
        if not SystemService.check_dep("sudo"):
            logger.error("sudo not available")
            return False
        password = SecureAuth.get_password()
        if not password:
            return False
        try:
            proc = subprocess.Popen(
                ["sudo", "-S", "sh", "-c", script],
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=False
            )
            _, stderr = proc.communicate(input=password + b'\n', timeout=30)
            if proc.returncode != 0:
                # Do not log stderr content as it might contain password fragments
                logger.error(f"sudo failed (return code {proc.returncode})")
                return False
            return True
        except Exception as e:
            logger.error(f"Elevated run error: {e}")
            return False
        finally:
            SecureAuth.wipe(password)

