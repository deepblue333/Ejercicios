class WikiEngine:
    """Generates wiki pages from knowledge base."""
    def __init__(self, kg: AegisKnowledge):
        self.kg = kg
        self.out_path = Path(config.get("wiki_output_path"))
        self.out_path.mkdir(parents=True, exist_ok=True)

    def rebuild_category(self, category: str):
        docs, metas = self.kg.query(f"All documentation for {category}", n_results=50, category=category)
        md = f"# AEGIS WIKI: {category.upper()}\n\nGenerated: {datetime.now()}\n\n"
        for d, m in zip(docs, metas):
            md += f"### Source: {m['source']}\n> {d}\n\n---\n"
        (self.out_path / f"{category}.md").write_text(md)

