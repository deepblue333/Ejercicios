class OllamaService:
    """Interface to Ollama LLM."""
    def __init__(self):
        self.model = config.get("ollama_model")
        self.timeout = config.get("ollama_timeout")
        self.base_url = "http://127.0.0.1:11434/api"
        if not REQUESTS_AVAILABLE:
            logger.error("Requests library missing. Ollama service disabled.")

    def list_models(self) -> List[str]:
        if not REQUESTS_AVAILABLE:
            return ["phi3:mini", "llama3", "mistral"]
        try:
            resp = requests.get(f"{self.base_url}/tags", timeout=3)
            if resp.status_code == 200:
                return [m['name'] for m in resp.json().get('models', [])]
        except:
            pass
        return ["phi3:mini", "llama3", "mistral"]

    def generate(self, prompt: str, context: str = "", retries: int = 2) -> str:
        if not REQUESTS_AVAILABLE:
            return "Error: requests library missing."
        full_prompt = f"{context}\n{prompt}" if context else prompt
        payload = {
            "model": self.model,
            "prompt": full_prompt,
            "stream": False,
            "options": {"temperature": 0.7}
        }
        for attempt in range(retries + 1):
            try:
                resp = requests.post(
                    f"{self.base_url}/generate",
                    json=payload,
                    timeout=self.timeout
                )
                resp.raise_for_status()
                return resp.json().get("response", "")
            except Exception as e:
                if attempt == retries:
                    logger.error(f"Ollama error: {e}")
                    return f"Error: {e}"
                time.sleep(2)
        return ""

# ============================================================================
# Mimir RAG (Volatile Session Memory)
# ============================================================================
class MimirRAG:
    """Volatile memory with simple keyword indexing."""
    def __init__(self):
        self.path = RAG_VOLATILE
        self.path.mkdir(exist_ok=True)
        self.session_salt = os.urandom(16).hex()
        self._index = {}  # keyword -> list of file names
        self._rebuild_index()

    def _rebuild_index(self):
        """Rebuild index from existing files."""
        self._index.clear()
        for f in self.path.glob("*.tmp"):
            try:
                content = f.read_text(errors='ignore')
                for word in set(w.lower() for w in content.split() if len(w) > 3):
                    self._index.setdefault(word, []).append(f.name)
            except:
                continue

    def commit(self, q: str, a: str, meta: Optional[Dict] = None):
        content = f"Q: {q}\nA: {a}\n"
        if meta:
            content += f"META: {json.dumps(meta)}\n"
        h = hashlib.sha256(f"{content}{self.session_salt}".encode()).hexdigest()[:12]
        fname = f"{h}.tmp"
        (self.path / fname).write_text(content)
        # Update index
        for word in set(w.lower() for w in content.split() if len(w) > 3):
            self._index.setdefault(word, []).append(fname)

    def fetch(self, query: str) -> str:
        keywords = [w.lower() for w in query.split() if len(w) > 3]
        candidates = set()
        for kw in keywords:
            for fname in self._index.get(kw, []):
                candidates.add(fname)
        results = []
        for fname in candidates:
            try:
                content = (self.path / fname).read_text(errors='ignore')
                results.append(content)
            except:
                continue
        return "\n---\n".join(results[-2:])

    def purge(self):
        for f in self.path.glob("*.tmp"):
            try:
                size = f.stat().st_size
                with open(f, "wb") as fw:
                    fw.write(os.urandom(size))
                f.unlink()
            except:
                pass
        self._index.clear()

