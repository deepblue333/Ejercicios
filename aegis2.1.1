class NotificationService:
    """Sends desktop notifications."""
    @staticmethod
    def notify(title: str, message: str):
        try:
            if subprocess.call(["which", "notify-send"], stdout=subprocess.DEVNULL) == 0:
                subprocess.run(["notify-send", f"AEGIS: {title}", message])
            elif subprocess.call(["which", "kdialog"], stdout=subprocess.DEVNULL) == 0:
                subprocess.run(["kdialog", "--title", f"AEGIS: {title}", "--passivepopup", message, "5"])
        except Exception as e:
            logger.warning(f"Notification failed: {e}")

